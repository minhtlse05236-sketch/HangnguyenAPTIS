@{
    ViewData["Title"] = "Chi tiết khoá học";
}

<section class="course-detail-hero">
    <div class="container">
        <div class="row g-5 align-items-center">
            <div class="col-lg-8">
                <span class="eyebrow">APTIS B1-B2 Intensive</span>
                <h1>Lộ trình tăng tốc cho mục tiêu B1-B2</h1>
                <p>Học kỹ thuật xử lý đề, luyện phản xạ với quiz sau mỗi bài và theo dõi tiến độ theo tuần.</p>
                <div class="d-flex flex-wrap gap-3">
                    <a class="btn btn-primary btn-lg" asp-controller="Home" asp-action="Lesson">Vào học ngay</a>
                    <a class="btn btn-outline-light btn-lg" asp-controller="Home" asp-action="Quiz">Làm quiz đầu vào</a>
                </div>
            </div>
            <div class="col-lg-4">
                <div class="detail-card">
                    <div><strong>36</strong><span>Bài học</span></div>
                    <div><strong>120</strong><span>Bài tập</span></div>
                    <div><strong>8</strong><span>Tuần học</span></div>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="section-pad">
    <div class="container">
        <div class="row g-4">
            <div class="col-lg-8">
                <h2>Nội dung khoá học</h2>
                <div class="module-list">
                    <div class="module-item"><span>01</span><div><strong>Grammar & Vocabulary Core</strong><p>Củng cố nền tảng qua ví dụ trong đề.</p></div></div>
                    <div class="module-item"><span>02</span><div><strong>Reading & Listening Strategy</strong><p>Luyện nhận diện bẫy và quản lý thời gian.</p></div></div>
                    <div class="module-item"><span>03</span><div><strong>Writing & Speaking Output</strong><p>Xây khung trả lời, sửa lỗi và luyện phản xạ.</p></div></div>
                </div>
            </div>
            <div class="col-lg-4">
                <aside class="side-panel">
                    <h3>Phù hợp với</h3>
                    <p>Người đã có nền tảng A2-B1 và cần lộ trình học có kiểm tra tiến độ rõ ràng.</p>
                </aside>
            </div>
        </div>
    </div>
</section>
