@{
    ViewData["Title"] = "Trang cá nhân";
}

<section class="profile-page">
    <div class="container">
        <div class="profile-header">
            <div class="avatar">HN</div>
            <div>
                <span class="eyebrow">Hồ sơ học viên</span>
                <h1>Hằng Nguyễn</h1>
                <p>Đang theo học APTIS B1-B2 Intensive</p>
            </div>
        </div>
        <div class="row g-4 mt-2">
            <div class="col-lg-4">
                <div class="profile-card">
                    <h2>Tiến độ</h2>
                    <div class="progress big" role="progressbar" aria-label="Tiến độ tổng" aria-valuenow="72" aria-valuemin="0" aria-valuemax="100">
                        <div class="progress-bar" style="width: 72%">72%</div>
                    </div>
                    <p class="mt-3 mb-0">Bạn đã hoàn thành 26/36 bài học.</p>
                </div>
            </div>
            <div class="col-lg-8">
                <div class="profile-card">
                    <h2>Lịch học gần đây</h2>
                    <div class="activity-row"><span>Hôm nay</span><strong>Hoàn thành quiz Relative clauses</strong></div>
                    <div class="activity-row"><span>Hôm qua</span><strong>Xem bài Writing Task 2</strong></div>
                    <div class="activity-row"><span>Tuần này</span><strong>Điểm mock test tăng 8%</strong></div>
                </div>
            </div>
        </div>
    </div>
</section>
