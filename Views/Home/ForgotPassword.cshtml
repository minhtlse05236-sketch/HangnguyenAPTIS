@{
    ViewData["Title"] = "Quên mật khẩu";
}

<section class="auth-page">
    <div class="auth-card">
        <span class="eyebrow">Khôi phục tài khoản</span>
        <h1>Quên mật khẩu</h1>
        <p class="text-muted">Nhập email đã đăng ký để nhận hướng dẫn đặt lại mật khẩu.</p>
        <form class="mt-4">
            <div class="mb-4">
                <label class="form-label" for="resetEmail">Email</label>
                <input class="form-control form-control-lg" id="resetEmail" type="email" placeholder="ban@example.com">
            </div>
            <button class="btn btn-primary btn-lg w-100" type="button">Gửi hướng dẫn</button>
        </form>
        <a class="d-inline-block mt-4" asp-controller="Home" asp-action="Login">Quay lại đăng nhập</a>
    </div>
</section>
