@{
    ViewData["Title"] = "Làm bài quiz";
}

<section class="quiz-page">
    <div class="quiz-shell">
        <div class="quiz-header">
            <div>
                <span class="eyebrow">Mini quiz</span>
                <h1>Grammar check: Relative clauses</h1>
            </div>
            <div class="quiz-timer">12:00</div>
        </div>
        <div class="progress mb-4" role="progressbar" aria-label="Tiến độ quiz" aria-valuenow="40" aria-valuemin="0" aria-valuemax="100">
            <div class="progress-bar" style="width: 40%">Câu 2/5</div>
        </div>
        <div class="question-card">
            <p class="question-number">Câu 2</p>
            <h2>Choose the sentence that uses a relative clause correctly.</h2>
            <div class="answer-list">
                <label><input type="radio" name="q2"> The teacher which helped me was very patient.</label>
                <label><input type="radio" name="q2"> The book who I bought is useful.</label>
                <label><input type="radio" name="q2"> The student who answered first got a point.</label>
                <label><input type="radio" name="q2"> The place what we visited was quiet.</label>
            </div>
        </div>
        <div class="d-flex justify-content-between mt-4">
            <button class="btn btn-outline-secondary" type="button">Câu trước</button>
            <button class="btn btn-primary" type="button">Câu tiếp theo</button>
        </div>
    </div>
</section>
