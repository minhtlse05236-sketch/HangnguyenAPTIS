@{
    ViewData["Title"] = "Bài viết";
}

<section class="page-hero compact">
    <div class="container">
        <span class="eyebrow">Thư viện kiến thức</span>
        <h1>Bài viết luyện thi APTIS</h1>
        <p>Mẹo học, phân tích dạng bài và chiến thuật làm bài dễ áp dụng.</p>
    </div>
</section>

<section class="section-pad">
    <div class="container">
        <div class="row g-4">
            <div class="col-lg-7">
                <article class="post-feature">
                    <span class="badge text-bg-primary">Nổi bật</span>
                    <h2>5 lỗi khiến bài Writing Task 2 mất điểm đáng tiếc</h2>
                    <p>Nhận diện lỗi về bố cục, register, linking words và cách sửa nhanh trước ngày thi.</p>
                    <a class="btn btn-outline-primary" asp-controller="Home" asp-action="Lesson">Đọc bài</a>
                </article>
            </div>
            <div class="col-lg-5">
                <div class="post-list">
                    <div class="post-row"><span>Reading</span><strong>Cách đọc câu hỏi trước khi scan bài</strong></div>
                    <div class="post-row"><span>Listening</span><strong>Ghi chú từ khoá mà không bỏ lỡ audio</strong></div>
                    <div class="post-row"><span>Speaking</span><strong>Mở rộng câu trả lời trong 20 giây</strong></div>
                    <div class="post-row"><span>Grammar</span><strong>12 cấu trúc hay xuất hiện trong APTIS</strong></div>
                </div>
            </div>
        </div>
    </div>
</section>
